{
  "name": "claude-control",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-account Claude Code switching, cross-account usage, and phone remote control.",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean && rimraf \"packages/*/dist\" \"packages/*/*.tsbuildinfo\"",
    "typecheck": "tsc -b --noEmit false && tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci:check": "pnpm run lint && pnpm run format:check && pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.2"
  }
}
