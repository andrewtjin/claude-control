# Copy to .env in this directory and fill in real values. .env is gitignored — the token and
# hostname below are deploy-time secrets/config, never committed.

# Discord application's bot token (Developer Portal -> Bot -> Reset Token). The bot process
# holds no other credential — see packages/control-plane-bot/src/index.ts.
DISCORD_BOT_TOKEN=

# Public hostname this VPS answers to. Caddy requests a TLS certificate for it and reverse
# proxies wss:// traffic to the bot; the CLI's default relay URL points at wss://<this>. Must
# already resolve to this machine's IP before `docker compose up` (Let's Encrypt needs to
# reach it over HTTP-01/TLS-ALPN-01 to issue the cert).
RELAY_HOSTNAME=relay.example.com
